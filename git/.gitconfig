# Personal config (name, email, GPG) lives in ~/.gitconfig.local
# Generated by: ./setup.sh
[include]
	path = ~/.gitconfig.local
[credential]
	helper = osxkeychain
[filter "lfs"]
	clean = git-lfs clean -- %f
	smudge = git-lfs smudge -- %f
	process = git-lfs filter-process
	required = true
[core]
	autocrlf = input
[push]
	autoSetupRemote = true
[alias]
	prune-local = "!git fetch -p && git branch -vv | grep ': gone]' | grep -vE '^\\*|\\s(main|master|development)\\s' | awk '{print $1}' | while read branch; do git branch -D \"$branch\"; done"
